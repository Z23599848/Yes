# Master node environment — copy to .env and fill in
BALE_PHONE=+989XXXXXXXXX          # Your Bale account phone number (with country code)
HEADLESS=false                     # Set to "true" for headless mode after first login
SESSION_FILE=/app/session/master_session.json
TUN_LOCAL_IP=10.0.0.1
TUN_PEER_IP=10.0.0.2
WS_BRIDGE_PORT=9876
INTERNET_IFACE=eth0               # The container's internet-facing interface
