# Slave node environment — copy to .env and fill in
BALE_PHONE=+989XXXXXXXXX          # Slave Bale account phone number (different from master!)
MASTER_BALE_PHONE=+989XXXXXXXXX   # Master's Bale phone number (to open chat & call)
HEADLESS=false                     # Set to "true" for headless mode after first login
SESSION_FILE=/app/session/slave_session.json
TUN_LOCAL_IP=10.0.0.2
TUN_PEER_IP=10.0.0.1
WS_BRIDGE_PORT=9877
WIFI_IFACE=wlan0                  # Physical WiFi adapter passed into container
HOTSPOT_SSID=BaleTunnel
HOTSPOT_PASS=tunnel1234
